# App (required)
JWT_SECRET_KEY=your-jwt-secret-key

# Slack OAuth
SLACK_CLIENT_ID=your-slack-client-id
SLACK_CLIENT_SECRET=your-slack-client-secret
SLACK_USER_SCOPES=emoji:read,users:read,users:read.email,usergroups:read,channels:history,groups:history,im:history,mpim:history,reactions:read

# Slack Events (request signing)
SLACK_SIGNING_SECRET=your-slack-signing-secret

# Tunnels backend; OAuth redirect URI = https://{NGROK_URL}/api/slack/oauth/callback
NGROK_AUTHTOKEN=your-ngrok-authtoken
NGROK_URL=your-name.ngrok-free.app
